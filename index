<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Keyboard Shortcuts Finder</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 30px;
      background: #f4f4f4;
    }

    h1 {
      text-align: center;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
    }

    #searchInput {
      width: 100%;
      padding: 12px;
      font-size: 16px;
      margin-bottom: 20px;
      border: 1px solid #ccc;
      border-radius: 8px;
    }

    .card {
      background: white;
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .shortcut {
      font-size: 20px;
      font-weight: bold;
      color: #1d4ed8;
    }

    .action {
      margin-top: 8px;
      font-size: 16px;
    }

    .owner {
      margin-top: 6px;
      color: #666;
      font-size: 14px;
    }

    .no-results {
      text-align: center;
      color: #888;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Keyboard Shortcuts Finder</h1>
    <input
      type="text"
      id="searchInput"
      placeholder="Search by shortcut or action..."
    />
    <div id="results"></div>
  </div>

  <script src="script.js"></script>
</body>
</html>
